@baseUrl = http://localhost:4000

### 1. Super Admin login (correct credentials) -> expect 200 + token
# @name login
POST {{baseUrl}}/api/superadmin/login
Content-Type: application/json

{
  "email": "{{$dotenv SUPER_ADMIN_EMAIL}}",
  "password": "{{$dotenv SUPER_ADMIN_PASSWORD}}"
}

### Capture the token from request #1's response (used by requests below)
@token = {{login.response.body.token}}

### 2. Super Admin login (wrong password) -> expect 401
POST {{baseUrl}}/api/superadmin/login
Content-Type: application/json

{
  "email": "{{$dotenv SUPER_ADMIN_EMAIL}}",
  "password": "wrong"
}

### 3. Create organization "Acme" -> expect 201 + signup_code
# @name createAcme
POST {{baseUrl}}/api/superadmin/orgs
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Acme"
}

### Capture Acme's codes
@acmeAdminCode = {{createAcme.response.body.admin_code}}
@acmeUserCode = {{createAcme.response.body.user_code}}

### 4. Create organization "Globex" -> expect 201 + signup_code
# @name createGlobex
POST {{baseUrl}}/api/superadmin/orgs
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Globex"
}

### Capture Globex's codes
@globexAdminCode = {{createGlobex.response.body.admin_code}}
@globexUserCode = {{createGlobex.response.body.user_code}}


### 5. List all organizations -> expect array of orgs
GET {{baseUrl}}/api/superadmin/orgs
Authorization: Bearer {{token}}

### 6. Create org WITHOUT token -> expect 401
POST {{baseUrl}}/api/superadmin/orgs
Content-Type: application/json

{
  "name": "Hacker"
}

### 7. Create duplicate org "Acme" again -> expect 409
POST {{baseUrl}}/api/superadmin/orgs
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Acme"
}

### 8. Health check (public, no auth)
GET {{baseUrl}}/api/health


### 9. Admin signup into "Acme" with valid code -> expect 201
POST {{baseUrl}}/api/admin/signup
Content-Type: application/json

{
  "email": "alice@acme.com",
  "password": "alicepass",
  "signupCode": "{{acmeAdminCode}}"
}

### 10. Admin signup with WRONG code -> expect 403
POST {{baseUrl}}/api/admin/signup
Content-Type: application/json

{
  "email": "mallory@acme.com",
  "password": "mallorypass",
  "signupCode": "totally-wrong-code"
}

### 11. ESCALATION: admin signup using Acme's USER code -> expect 403
POST {{baseUrl}}/api/admin/signup
Content-Type: application/json

{ "email": "sneaky@acme.com", 
  "password": "sneakypass", 
  "signupCode": "{{acmeUserCode}}" 
}

### 12. Admin signup duplicate email (valid admin code) -> expect 409
POST {{baseUrl}}/api/admin/signup
Content-Type: application/json

{ 
  "email": "alice@acme.com", 
  "password": "whatever", 
  "signupCode": "{{acmeAdminCode}}" 
}

### 13. Admin login (correct) -> expect 200 + token
# @name adminLogin
POST {{baseUrl}}/api/admin/login
Content-Type: application/json

{
  "email": "alice@acme.com",
  "password": "alicepass"
}

### Capture the admin token (used in Phase 4B for flag CRUD)
@adminToken = {{adminLogin.response.body.token}}

### 14. Admin login (wrong password) -> expect 401
POST {{baseUrl}}/api/admin/login
Content-Type: application/json

{
  "email": "alice@acme.com",
  "password": "nope"
}


### 15. Globex admin signup (valid admin code) -> expect 201
POST {{baseUrl}}/api/admin/signup
Content-Type: application/json

{ 
  "email": "bob@globex.com", 
  "password": "bobpass", 
  "signupCode": "{{globexAdminCode}}" 
}

### 16. Globex admin login -> expect 200 + token
# @name globexLogin
POST {{baseUrl}}/api/admin/login
Content-Type: application/json

{
  "email": "bob@globex.com",
  "password": "bobpass"
}

### Capture Globex admin token
@globexToken = {{globexLogin.response.body.token}}

### 17. Acme: create flag "dark_mode" (enabled) -> expect 201
POST {{baseUrl}}/api/admin/flags
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "key": "dark_mode",
  "enabled": true
}

### 18. Acme: create flag "beta_feature" (default disabled) -> expect 201
POST {{baseUrl}}/api/admin/flags
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "key": "beta_feature"
}

### 19. Acme: duplicate "dark_mode" -> expect 409
POST {{baseUrl}}/api/admin/flags
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "key": "dark_mode"
}

### 20. Acme: list flags -> expect 2 flags (dark_mode, beta_feature)
GET {{baseUrl}}/api/admin/flags
Authorization: Bearer {{adminToken}}

### 21. Acme: disable "dark_mode" -> expect 200, enabled=false
PATCH {{baseUrl}}/api/admin/flags/dark_mode
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "enabled": false
}

### 22. ISOLATION: Globex lists flags -> expect [] (cannot see Acme's)
GET {{baseUrl}}/api/admin/flags
Authorization: Bearer {{globexToken}}

### 23. ISOLATION: Globex toggles Acme's "dark_mode" -> expect 404
PATCH {{baseUrl}}/api/admin/flags/dark_mode
Content-Type: application/json
Authorization: Bearer {{globexToken}}

{
  "enabled": true
}

### 24. Create flag WITHOUT token -> expect 401
POST {{baseUrl}}/api/admin/flags
Content-Type: application/json

{
  "key": "sneaky"
}

### 25. Acme: create flag with missing key -> expect 400
POST {{baseUrl}}/api/admin/flags
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "enabled": true
}

### 26. Acme: delete "beta_feature" -> expect 200
DELETE {{baseUrl}}/api/admin/flags/beta_feature
Authorization: Bearer {{adminToken}}


### 27. End-user signup into Acme (valid user code) -> expect 201
POST {{baseUrl}}/api/user/signup
Content-Type: application/json

{ 
  "email": "eve@acme.com", 
  "password": "evepass", 
  "signupCode": "{{acmeUserCode}}" 
  }

### 28. ESCALATION (reverse): user signup using Acme's ADMIN code -> expect 403
POST {{baseUrl}}/api/user/signup
Content-Type: application/json

{ 
  "email": "eve2@acme.com", 
  "password": "evepass", 
  "signupCode": "{{acmeAdminCode}}" 
}

### 29. End-user login -> expect 200 + token
# @name userLogin
POST {{baseUrl}}/api/user/login
Content-Type: application/json

{ 
  "email": "eve@acme.com", 
  "password": "evepass"
}

### Capture end-user token
@userToken = {{userLogin.response.body.token}}

### 30. Check "dark_mode" (currently disabled) -> expect enabled:false
POST {{baseUrl}}/api/user/features/check
Content-Type: application/json
Authorization: Bearer {{userToken}}

{ "key": "dark_mode" }

### 31. Admin re-enables "dark_mode" -> expect 200
PATCH {{baseUrl}}/api/admin/flags/dark_mode
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "enabled": true }

### 32. Check "dark_mode" again -> expect enabled:true
POST {{baseUrl}}/api/user/features/check
Content-Type: application/json
Authorization: Bearer {{userToken}}

{ "key": "dark_mode" }

### 33. Check unknown flag -> expect enabled:false (unknown = disabled)
POST {{baseUrl}}/api/user/features/check
Content-Type: application/json
Authorization: Bearer {{userToken}}

{ "key": "no_such_flag" }

### 34. Check WITHOUT token -> expect 401
POST {{baseUrl}}/api/user/features/check
Content-Type: application/json

{ "key": "dark_mode" }

### 35. Admin token on the end-user check -> expect 403 (wrong role)
POST {{baseUrl}}/api/user/features/check
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{ "key": "dark_mode" }